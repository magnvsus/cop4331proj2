API_PORT=5000
API_DOMAIN=https://your-domain.com
MONGODB_URI=<your MongoDB connection string>
MONGODB_DB_NAME=<your database name>
JWT_SECRET=<a random secret string>
JWT_EXPIRES_IN=24h
EMAIL_USER=<your Gmail address>
EMAIL_APP_PASSWORD=<a Gmail App Password -- not your regular password>
EMAIL_FROM=<optional; defaults to EMAIL_USER>

# Days after a user verifies their email before their account is
# automatically deactivated (blocked from logging in). Optional; defaults to 7.
ACCOUNT_DEACTIVATION_DAYS=7

# Days after deactivation before the account (and all its data) is
# permanently deleted, if it's never reactivated by clicking a fresh
# verification/reactivation link. Optional; defaults to 7.
ACCOUNT_DELETION_GRACE_DAYS=7

